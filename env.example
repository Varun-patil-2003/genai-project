# ============================================================
# NetOps AI Sentinel — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git. It is already in .gitignore.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_ENV=development                        # development | staging | production
APP_NAME=NetOps AI Sentinel
APP_VERSION=0.1.0
DEBUG=true                                 # Set false in production
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR

# ── API Server ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true                            # Set false in production
API_SECRET_KEY=your-secret-key-here       # Used for JWT / session signing

# ── LLM Providers ────────────────────────────────────────────

# Anthropic (Claude) — primary LLM for classifier + RCA generation
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI — fallback or embedding model
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Groq — fast inference for latency-sensitive paths
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── Module A — Classifier ────────────────────────────────────
CLASSIFIER_CONFIDENCE_THRESHOLD=0.75      # Below this → escalate to human review
CLASSIFIER_MODEL_PATH=models/classifier_v1.pkl
CLASSIFIER_LABELS_PATH=models/labels.json

# ── Module B — RAG / Knowledge Brain ────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2          # sentence-transformers model
FAISS_INDEX_PATH=embeddings/faiss.index
FAISS_METADATA_PATH=embeddings/metadata.json
RAG_CHUNK_SIZE=512                         # Characters per chunk
RAG_CHUNK_OVERLAP=64                       # Overlap between chunks
RAG_TOP_K=5                                # Number of results to retrieve
DATA_RAW_PATH=data/raw                     # Source PDFs directory
DATA_TICKETS_PATH=data/sample_tickets      # Source JSON tickets directory

# ── Module C — Anomaly Detection + RCA ──────────────────────
ANOMALY_CONTAMINATION=0.05                 # Isolation Forest contamination param (0.01–0.1)
ANOMALY_LOOKBACK_MINUTES=60               # How far back to scan logs on ticket resolve
RCA_OUTPUT_DIR=reports                     # Where generated PDF RCA reports are saved
RCA_TEMPLATE=prompts/rca/rca_template.jinja2

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/netops_sentinel
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false                              # Set true to log all SQL queries

# ── LangSmith (optional — LangChain tracing) ────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=netops-sentinel

# ── Streamlit (Phase 1 UI) ───────────────────────────────────
STREAMLIT_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# ── Data Sources (Telecom/UC infra) ─────────────────────────
# Add connection strings for CUCM, SBC, TPO, TSS if pulling live logs
CUCM_API_URL=https://cucm.internal:8443
CUCM_USERNAME=admin
CUCM_PASSWORD=

SBC_LOG_PATH=/var/log/sbc
TPO_API_URL=
TSS_API_URL=
